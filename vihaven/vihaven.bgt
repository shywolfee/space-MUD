changelog.insert_last("- Server config (address and port) now saved in settings and always visible");
changelog.insert_last("- Removed localhost and beta server menu shortcuts");
changelog.insert_last("- Removed name field from options (handled by accounts)");
changelog.insert_last("- Item pickup and weapon equip messages are now consistent");
changelog.insert_last("- Fixed who command trailing comma");
changelog.insert_last("- Private messages now give feedback when player not found");
changelog.insert_last("- Chat rate limiting now tells you when you are sending too fast");
