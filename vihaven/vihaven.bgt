// Audio and UI libraries
#include "includes/sp.bgt"
#include "includes/buffer.bgt"
#include "includes/dlg.bgt"
#include "includes/form.bgt"
#include "includes/m_pro.bgt"
#include "includes/virtualizer.bgt"
#include "includes/submenu_system.bgt"
// Utilities
#include "includes/dateandtime.bgt"
#include "includes/chathistory.bgt"
// Game systems
#include "includes/bullet.bgt"
#include "includes/zone.bgt"
#include "includes/voicechatting.bgt"
// Core game logic (split from old monolithic chat.bgt)
#include "includes/connection.bgt"
#include "includes/prefsmanager.bgt"
#include "includes/chat.bgt"
#include "includes/game.bgt"
timer pingtimer;
int x=150;
timer walktimer;
double yversion=0.4;
voicechatting vc;
dynamic_menu_pro menu;
string prefsdir=DIRECTORY_APPDATA+"/"+"Obsidian";
int usound;
string name="noName"+random(0,9999), company="obsidian", version="0.5 beta";
instance game("system");
sound_pool p, chat;
virtualizer v;
int menuscroll;
bool sentpacket=false;
bool rules_accepted=false;
string[] last_inv;
string[] changelog;
string rules_text;
string stored_user="";
string stored_pass="";
string stored_email="";
audio_form af;
void main()
{
if(screen_reader_is_running(1))
install_keyhook();
show_game_window("Obsidian "+version);
set_sound_storage("sounds.dat");
if(!directory_exists(prefsdir))
{
directory_create(prefsdir);
}
load_rules();
load_changelog();
readprefs();
if(game.is_already_running) exit();
wait(100);
if(screen_reader_is_running(1))
install_keyhook();
net.setup_client(3, 500);
newzone("battlefield",1,300);
if(!rules_accepted)
{
show_rules_screen();
}
mainmenu();
}
void load_rules()
{
if(file_exists("rules.txt"))
{
file f;
f.open("rules.txt", "r");
rules_text = f.read();
f.close();
}
else
{
rules_text = "No rules file found. Please ensure rules.txt exists in the game directory.";
}
}
void load_changelog()
{
changelog.resize(0);
changelog.insert_last("Version 0.5 beta - Obsidian");
