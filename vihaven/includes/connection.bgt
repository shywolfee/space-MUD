// Connection and networking
bool encrypting=true, connected, terminating, exiting;
network net;
network_event event;
timer connectiontimer, terminating_timer, exittimer;
int connectingtime=10000, terminating_time=1500, exittime=3000;
string ip="sightlesswolf.com";
int client_port=38294;
bool send_reliable(int peer_id, string packet, int channel)
{
if(encrypting) packet=string_encrypt(packet, "rscs123");
return net.send_reliable(peer_id, packet, channel);
}
string get_event_message()
{
if(encrypting) return string_decrypt(event.message, "rscs123");
else return event.message;
}
void login()
{
if(stored_user == "" or stored_pass == "")
{
dlg("No account set up. Please set up an account first.");
connection_menu();
return;
}
speak("Connecting as "+stored_user);
net.connect(ip, client_port);
connectiontimer.restart();
while(true)
{
chat.update_listener_1d(x);
event=net.request();
wait(5);
if(connectiontimer.elapsed>=connectingtime and connected==false or event.type==event_disconnect)
{
connectiontimer.restart();
connected=false;
setupmenu();
menu.add_item_tts("Try again", "retry");
menu.add_item_tts("Back", "back");
int result = menu.run("Could not reach the server", true);
if(menu.get_item_name(result) == "retry")
{
speak("Reconnecting...");
net.connect(ip, client_port);
connectiontimer.restart();
continue;
}
else
{
connection_menu();
return;
}
}
else if(event.type==event_connect and connected==false)
{
send_reliable(0, "login "+stored_user+" "+stored_pass+" "+yversion, 0);
p.play_stationary("amb.ogg",true);
connected=true;
}
if(event.type==event_receive and get_event_message()=="done")
{
name = stored_user;
livechat();
}
else if(event.type==event_receive and string_contains(get_event_message(), "error:", 1)>-1)
{
dlg(get_event_message());
connected=false;
connection_menu();
return;
}
}
}
void leavechat()
{
sentpacket=false;
send_reliable(0, "disconnect", 0);
exittimer.restart();
exiting=true;
}
